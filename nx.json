{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "sharedGlobals": [],
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "production": [
      "default"
    ]
  },
  "plugins": [
    {
      "plugin": "@nx/angular/plugin",
      "options": {
        "buildTargetName": "build",
        "testTargetName": "test",
        "serveTargetName": "serve",
        "extractI18nTargetName": "extract-i18n",
        "lintTargetName": "lint",
        "serveStaticTargetName": "serve-static",
        "e2eTestTargetName": "e2e"
      }
    }
  ],
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "production",
        "^production"
      ]
    },
    "test": {
      "cache": true
    },
    "lint": {
      "cache": true
    }
  },
  "defaultBase": "main",
  "nxCloudId": "6a072705729fbc14e4ab823e",
  "analytics": false,
  "generators": {
    "@nx/angular:component": {
      "style": "css"
    }
  }
}
